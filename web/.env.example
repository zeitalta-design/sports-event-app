# ============================================================
# スポ活 (SpoKatsu) — 環境変数テンプレート
# ============================================================
# このファイルを .env.local にコピーして値を設定してください
#   cp .env.example .env.local
# ============================================================

# --- アプリケーション基本設定 ---
# 本番ドメイン（末尾スラッシュなし）
APP_BASE_URL=https://your-domain.com

# Node.js 環境（production / development）
NODE_ENV=production

# --- セッション / 認証（本番必須） ---
# セッショントークンの HMAC 署名に使用（32文字以上のランダム文字列）
# ⚠️ 本番では必須。未設定だとサーバーが起動しません
# 生成: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# --- メール送信（SMTP） ---
# パスワードリセット等のメール送信に使用
# 未設定の場合は Ethereal（テスト用）にフォールバック
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
MAIL_FROM=スポ活 <noreply@your-domain.com>

# --- Google Analytics（任意） ---
# GA4 測定 ID（未設定の場合はトラッキング無効）
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# --- データベース ---
# SQLite ファイルパス（デフォルト: ./data/sports-event.db）
# VPS 環境ではデータ永続化ディレクトリを指定
# DB_PATH=./data/sports-event.db
