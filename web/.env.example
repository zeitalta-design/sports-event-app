# ============================================
# 比較サイト OS — 環境変数設定
# ============================================
# このファイルを .env にコピーして値を設定してください。
#   cp .env.example .env
#
# .env は .gitignore に含まれるため、リポジトリにはコミットされません。
# shell で直接指定した環境変数は .env より優先されます。
# 本番設定の詳細は docs/deploy-checklist.md を参照。

# ─── 基本設定 ──────────────────────────────
# サイトの公開 URL（sitemap, OGP, メールリンクで使用）
APP_BASE_URL=http://localhost:3001

# ─── 認証 / セッション ─────────────────────
# セッション署名キー（本番では必ずランダムな長い文字列を設定）
SESSION_SECRET=

# ─── 初期管理者アカウント ─────────────────────
# admin ユーザーが 0 人のとき、起動時に自動作成される
# 本番ではデフォルト値（admin@example.com / admin123）は禁止
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123

# ─── メール送信 ────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=

# ─── Google Analytics（任意）───────────────
# NEXT_PUBLIC_GA_ID=

# ─── 外部画像（任意）──────────────────────
# UNSPLASH_ACCESS_KEY=

# ─── LLM / AI（任意）─────────────────────
# LLM_ENABLED=false
# LLM_PROVIDER=
# LLM_BASE_URL=
# LLM_API_KEY=
# LLM_MODEL=
# LLM_MAX_TOKENS=
# LLM_TIMEOUT_MS=

# ─── Ops / 内部ジョブ保護 ─────────────────
# cron ジョブの認証用シークレット
# OPS_CRON_SECRET=
# OPS_ADMIN_EMAIL=
# OPS_SLACK_WEBHOOK_URL=
# OPS_NOTIFY_CHANNELS=

# ─── Remote Import URLs ────────────────────
# run-imports.js --all / --domain <name> で使用
YUTAI_IMPORT_URL=
HOJOKIN_IMPORT_URL=
NYUSATSU_IMPORT_URL=
MINPAKU_IMPORT_URL=

# ─── Source Adapter URLs ───────────────────
# import-*.js --source primary / run-imports.js --source primary で使用
YUTAI_SOURCE_PRIMARY_URL=
HOJOKIN_SOURCE_PRIMARY_URL=
NYUSATSU_SOURCE_PRIMARY_URL=
MINPAKU_SOURCE_PRIMARY_URL=

# ─── Source Adapter Tokens（任意）──────────
# 認証付き API の場合に設定
# YUTAI_SOURCE_PRIMARY_TOKEN=
# HOJOKIN_SOURCE_PRIMARY_TOKEN=
# NYUSATSU_SOURCE_PRIMARY_TOKEN=
# MINPAKU_SOURCE_PRIMARY_TOKEN=

# ─── Stripe 課金（Phase M-4）──────────────
# 入札ナビ Pro ¥3,980/月 の月額課金
# 1) https://dashboard.stripe.com で Product「入札ナビ Pro」¥3,980/月 Recurring を作成
# 2) 作成された Price ID (price_...) を STRIPE_PRICE_ID に
# 3) Developers → API keys で Secret key (sk_test_... / sk_live_...) を STRIPE_SECRET_KEY に
# 4) Developers → Webhooks → Add endpoint
#      URL:    https://{your-domain}/api/stripe/webhook
#      Events: checkout.session.completed, invoice.payment_failed, customer.subscription.deleted
#    作成後に表示される Signing secret (whsec_...) を STRIPE_WEBHOOK_SECRET に
# STRIPE_SECRET_KEY=sk_test_xxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxx
# STRIPE_PRICE_ID=price_xxxxx
# NEXT_PUBLIC_BASE_URL=http://localhost:3001
