# ============================================
# 比較サイト OS — 環境変数設定
# ============================================
# このファイルを .env にコピーして値を設定してください。
#   cp .env.example .env
#
# .env は .gitignore に含まれるため、リポジトリにはコミットされません。
# shell で直接指定した環境変数は .env より優先されます。
# 本番設定の詳細は docs/deploy-checklist.md を参照。

# ─── 基本設定 ──────────────────────────────
# サイトの公開 URL（sitemap, OGP, メールリンクで使用）
APP_BASE_URL=http://localhost:3001

# ─── 認証 / セッション ─────────────────────
# セッション署名キー（本番では必ずランダムな長い文字列を設定）
SESSION_SECRET=

# ─── メール送信 ────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=

# ─── Google Analytics（任意）───────────────
# NEXT_PUBLIC_GA_ID=

# ─── 外部画像（任意）──────────────────────
# UNSPLASH_ACCESS_KEY=

# ─── LLM / AI（任意）─────────────────────
# LLM_ENABLED=false
# LLM_PROVIDER=
# LLM_BASE_URL=
# LLM_API_KEY=
# LLM_MODEL=
# LLM_MAX_TOKENS=
# LLM_TIMEOUT_MS=

# ─── Ops / 内部ジョブ保護 ─────────────────
# cron ジョブの認証用シークレット
# OPS_CRON_SECRET=
# OPS_ADMIN_EMAIL=
# OPS_SLACK_WEBHOOK_URL=
# OPS_NOTIFY_CHANNELS=

# ─── Remote Import URLs ────────────────────
# run-imports.js --all / --domain <name> で使用
YUTAI_IMPORT_URL=
HOJOKIN_IMPORT_URL=
NYUSATSU_IMPORT_URL=
MINPAKU_IMPORT_URL=

# ─── Source Adapter URLs ───────────────────
# import-*.js --source primary / run-imports.js --source primary で使用
YUTAI_SOURCE_PRIMARY_URL=
HOJOKIN_SOURCE_PRIMARY_URL=
NYUSATSU_SOURCE_PRIMARY_URL=
MINPAKU_SOURCE_PRIMARY_URL=

# ─── Source Adapter Tokens（任意）──────────
# 認証付き API の場合に設定
# YUTAI_SOURCE_PRIMARY_TOKEN=
# HOJOKIN_SOURCE_PRIMARY_TOKEN=
# NYUSATSU_SOURCE_PRIMARY_TOKEN=
# MINPAKU_SOURCE_PRIMARY_TOKEN=
