    "jobs:daily:full": "node ../scripts/run-daily-jobs.js --with-email-send",
    "jobs:daily:dry": "node ../scripts/run-daily-jobs.js --dry-run",
    "emails:generate": "node ../scripts/generate-email-jobs.js",
    "emails:send": "node ../scripts/send-emails.js",
    "emails:send:dry": "node ../scripts/send-emails.js --dry-run",
    "seed:searches": "node ../scripts/seed-saved-searches.js",
    "seed:users": "node ../scripts/seed-users.js",
    "cleanup:old-data": "node ../scripts/cleanup-old-data.js",
    "reclassify:sport-types": "node ../scripts/reclassify-sport-types.js",
