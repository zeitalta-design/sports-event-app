{
  "name": "risk-monitor",
  "version": "1.0.0",
  "description": "企業リスク監視プラットフォーム（行政処分・入札情報・補助金など横断検索）",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001 --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "init-db": "node ../scripts/init-db.js",
    "seed": "node ../scripts/seed.js",
    "scrape:runnet:list": "node ../scripts/scrape-runnet-list.js",
    "scrape:runnet:list:full": "node ../scripts/scrape-runnet-list.js --pages 106",
    "scrape:runnet:list:new": "node ../scripts/scrape-runnet-list.js --pages 106 --only-new",
    "scrape:runnet:detail": "node ../scripts/scrape-runnet-detail.js",
    "scrape:runnet:detail:batch": "node ../scripts/scrape-runnet-detail.js --all",
    "scrape:moshicom:detail": "node ../scripts/scrape-moshicom-detail.js --only-missing-races",
    "notifications:generate": "node ../scripts/generate-notifications.js",
