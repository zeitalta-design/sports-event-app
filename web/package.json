    "fetch:hojokin": "node scripts/fetch-hojokin.mjs",
    "fetch:kyoninka": "node scripts/fetch-kyoninka.mjs",
    "fetch:kyoninka:preview": "node scripts/fetch-kyoninka.mjs --preview",
    "fetch:sanpai": "node scripts/fetch-sanpai.mjs",
    "fetch:sanpai:dry": "node scripts/fetch-sanpai.mjs --dry-run",
    "fetch:nyusatsu": "node scripts/fetch-nyusatsu.mjs",
    "fetch:nyusatsu:dry": "node scripts/fetch-nyusatsu.mjs --dry-run",
    "fetch:shitei": "node scripts/fetch-shitei.mjs",
    "fetch:shitei:dry": "node scripts/fetch-shitei.mjs --dry-run",
    "fetch:mhlw-black": "node scripts/fetch-gyosei-shobun-mhlw.mjs",
    "fetch:fsa-jirei": "node scripts/fetch-gyosei-shobun-fsa.mjs",
    "fetch:jftc": "node scripts/fetch-gyosei-shobun-jftc.mjs",
    "fetch:caa": "node scripts/fetch-gyosei-shobun-caa.mjs",
    "fetch:mlit-transport": "node scripts/fetch-gyosei-shobun-mlit-transport.mjs"
